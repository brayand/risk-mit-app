# Meridian Risk Lab — Environment Variables
# Copy this file to .env and fill in your free API keys

# EIA (Energy Information Administration)
# Get free key at: https://www.eia.gov/opendata/
EIA_API_KEY=your_eia_key_here

# FRED (Federal Reserve Economic Data)
# Get free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# NREL (National Renewable Energy Laboratory)
# Get free key at: https://developer.nrel.gov/signup/
NREL_API_KEY=your_nrel_key_here

# Database path (default: backend/output/meridian.db)
# DB_PATH=./output/meridian.db
